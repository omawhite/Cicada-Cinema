---
import "../global.css";
import { LayoutShell } from "../components/LayoutShell";

interface Props {
  title?: string;
}

const { title = "Cicada Cinema" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/Cicada_Cinema_2024_icon_5-circle-white_80x@2x.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <LayoutShell>
      <slot />
    </LayoutShell>
  </body>
</html>
